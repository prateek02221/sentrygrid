APP_NAME=Mini SOC Platform
APP_VERSION=1.0.0
DEBUG=false
API_PREFIX=/api/v1

MONGODB_URL=your-mongodb-atlas-connection-string
DATABASE_NAME=mini_soc

JWT_SECRET_KEY=change-this-to-a-long-random-string
JWT_REFRESH_SECRET_KEY=change-this-to-a-different-long-random-string
JWT_ALGORITHM=HS256

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Comma-separated list of allowed frontend origins.
# Local dev example: http://localhost:5173
# Production (single-service deploy): your Render URL, e.g. https://mini-soc.onrender.com
ALLOWED_ORIGINS=http://localhost:5173

# Auto threat generation (background scheduler)
AUTO_THREAT_GENERATION_ENABLED=true
AUTO_THREAT_GENERATION_INTERVAL_HOURS=2
